# --------------------------------------------------------------------
# Database (Required)
# --------------------------------------------------------------------
# Runtime connection (Supabase pooler)
# Note:
# - Keep sslmode=require
# - uselibpqcompat=true avoids pg SSL compatibility issues seen in Vercel runtime
DATABASE_URL="postgresql://postgres.<project_ref>:<urlencoded_password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true"

# Direct connection (migration/admin use)
DIRECT_URL="postgresql://postgres:<urlencoded_password>@db.<project_ref>.supabase.co:5432/postgres?sslmode=require"

# Vercel environment mapping:
# - Production  -> DATABASE_URL/DIRECT_URL from tabi-ai-prod
# - Preview     -> DATABASE_URL/DIRECT_URL from tabi-ai-dev
# - Development -> DATABASE_URL/DIRECT_URL from tabi-ai-dev

# --------------------------------------------------------------------
# AI / Tool providers (Required for full pipeline)
# --------------------------------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY="your_google_gemini_api_key"
DEEPSEEK_API_KEY="your_deepseek_api_key"
APIFY_API_KEY="your_apify_api_key"
UNSPLASH_ACCESS_KEY="your_unsplash_access_key"

# Optional: override Apify actor (default in code path may be used if absent)
APIFY_YOUTUBE_ACTOR_ID="streamers~youtube-scraper"

# --------------------------------------------------------------------
# OAuth (Optional, required only if you enable Google/GitHub sign-in)
# --------------------------------------------------------------------
AUTH_GOOGLE_CLIENT_ID="your_google_oauth_client_id"
AUTH_GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"
AUTH_GITHUB_CLIENT_ID="your_github_oauth_client_id"
AUTH_GITHUB_CLIENT_SECRET="your_github_oauth_client_secret"

# --------------------------------------------------------------------
# Supabase API keys (Optional; not required for current DB-only cutover)
# --------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://<project_ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
