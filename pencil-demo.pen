                                                  "name": "{\n  \"title\": \"Izakaya hopping in Osaka\",\n  \"blocks",
                                                  "fill": "#6b6560ff",
                                                  "textGrowth": "fixed-width",
                                                  "width": 319,
                                                  "content": "{\n  \"title\": \"Izakaya hopping in Osaka\",\n  \"blocks\": [\n    {\n      \"type\": \"spot\",\n      \"title\": \"Exploring Umeda and Osaka Station City\",\n      \"block_id\": \"JCzy_jfp\",\n      \"location\": null,\n      \"smart_tags\": [\n        \"#city-exploration\",\n        \"#transport-hub\",\n        \"#architecture\"\n      ],\n      \"description\": \"Discovering the bustling business and transport hub of Umeda and the massive Osaka Station City, a complex of rail terminals, shopping centers, and restaurants.\"\n    },\n    {\n      \"type\": \"food\",\n      \"title\": \"Seafood Feast at Isomaru Suisan Izakaya\",\n      \"block_id\": \"pHDKSWvj\",\n      \"location\": null,\n      \"smart_tags\": [\n        \"#seafood\",\n        \"#izakaya\",\n        \"#bonito-tataki\"\n      ],\n      \"description\": \"Starting the izakaya hopping at a well-known seafood chain restaurant, enjoying dishes like Bonito tataki, grilled squid, and sushi with caviar and sea urchins.\"\n    },\n    {\n      \"type\": \"food\",\n      \"title\": \"Happy Hour at Izakaya Don\",\n      \"block_id\": \"ginNzwMq\",\n      \"location\": null,\n      \"smart_tags\": [\n        \"#happy-hour\",\n        \"#cheap-drinks\",\n        \"#izakaya\"\n      ],\n      \"description\": \"Taking advantage of a happy hour with dirt-cheap alcohol. Trying a variety of dishes including fried octopus, horse sashimi, and a creamy gyoza soup.\"\n    },\n    {\n      \"type\": \"shopping\",\n      \"title\": \"Strolling Through Tenjinbashi Shopping Arcade\",\n      \"block_id\": \"QXVxqz5Z\",\n      \"location\": null,\n      \"smart_tags\": [\n        \"#shopping-arcade\",\n        \"#local-life\",\n        \"#walking-tour\"\n      ],\n      \"description\": \"Taking a digestive walk through the lively Tenjinbashi shopping strip, a traditional Japanese arcade, on the way to a local shrine.\"\n    },\n    {\n      \"type\": \"spot\",\n      \"title\": \"Visiting the Historic Osaka Tenmangu Shrine\",\n      \"block_id\": \"92xUh7sl\",\n      \"location\": null,\n      \"smart_tags\": [\n        \"#shrine\",\n        \"#cultural-site\",\n        \"#historical\"\n      ],\n      \"description\": \"Visiting one of Japan's most important shrines, dedicated to the Shinto deity Tenjin, which has been around since the 10th century.\"\n    },\n    {\n      \"type\": \"food\",\n      \"title\": \"Takoyaki and Yakisoba at Shugetsu\",\n      \"block_id\": \"EQhh2X3p\",\n      \"location\": null,\n      \"smart_tags\": [\n        \"#takoyaki\",\n        \"#yakisoba\",\n        \"#osaka-street-food\"\n      ],\n      \"description\": \"Continuing the food tour at a takoyaki house. Trying different flavors of takoyaki and shio yakisoba (salt-flavored fried noodles).\"\n    },\n    {\n      \"type\": \"food\",\n      \"title\": \"Final Izakaya Stop for Kushikatsu Skewers\",\n      \"block_id\": \"Bc5Rmwa9\",\n      \"location\": null,\n      \"smart_tags\": [\n        \"#kushikatsu\",\n        \"#skewers\",\n        \"#food-hall\"\n      ],\n      \"description\": \"Finishing the izakaya hopping adventure at a kushikatsu bar in the Lucua Shopping Center Food Hall, eating skewed meat and vegetables.\"\n    },\n    {\n      \"type\": \"transport\",\n      \"title\": \"Saying Goodbye at the Shinkansen Station\",\n      \"block_id\": \"d-AaSYur\",\n      \"location\": null,\n      \"smart_tags\": [\n        \"#shinkansen\",\n        \"#bullet-train\",\n        \"#travel\"\n      ],\n      \"description\": \"Concluding the day by seeing a friend off as she boards the Shinkansen bullet train to go home after a fun day of izakaya hopping.\"\n    }\n  ],\n  \"videoId\": \"re7H1xsqG8Q\",\n  \"videoUrl\": \"https://www.youtube.com/watch?v=re7H1xsqG8Q\",\n  \"spotCount\": 2,\n  \"blockCount\": 8,\n  \"guideTitle\": \"Izakaya hopping in Osaka\",\n  \"spot_blocks\": [\n    {\n      \"title\": \"Exploring Umeda and Osaka Station City\",\n      \"block_id\": \"JCzy_jfp\",\n      \"location\": null,\n      \"smart_tags\": [\n        \"#city-exploration\",\n        \"#transport-hub\",\n        \"#architecture\"\n      ],\n      \"description\": \"Discovering the bustling business and transport hub of Umeda and the massive Osaka Station City, a complex of rail terminals, shopping centers, and restaurants.\"\n    },\n    {\n      \"title\": \"Visiting the Historic Osaka Tenmangu Shrine\",\n      \"block_id\": \"92xUh7sl\",\n      \"location\": null,\n      \"smart_tags\": [\n        \"#shrine\",\n        \"#cultural-site\",\n        \"#historical\"\n      ],\n      \"description\": \"Visiting one of Japan's most important shrines, dedicated to the Shinto deity Tenjin, which has been around since the 10th century.\"\n    }\n  ],\n  \"thumbnailUrl\": \"https://i.ytimg.com/vi/re7H1xsqG8Q/maxresdefault.jpg\",\n  \"coverImageUrl\": \"https://i.ytimg.com/vi/re7H1xsqG8Q/maxresdefault.jpg\"\n}",
